# App
NODE_ENV=development
PORT=3000
API_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=finance_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:your_strong_postgres_password@localhost:5432/finance_db
DATABASE_URL_DOCKER=postgresql://postgres:your_strong_postgres_password@postgres:5432/finance_db

# Auth
JWT_SECRET=replace_with_minimum_32_char_random_secret
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
